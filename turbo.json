{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vitepress/dist/**"],
      "env": ["VITE_BASE_PATH"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["PORT"]
    },
    "@repo/docs#build": {
      "dependsOn": ["sync:configurator"],
      "outputs": [".vitepress/dist/**"],
      "env": ["VITE_BASE_PATH"]
    },
    "sync:configurator": {
      "dependsOn": ["@repo/webapp#build"],
      "cache": false
    },
    "lint": {},
    "typecheck": {}
  }
}
