{
  "name": "showwhat",
  "version": "1.0.1",
  "description": "A schema-based resolution engine for configuration and feature flags",
  "keywords": [
    "feature-flags",
    "feature-toggles",
    "feature-management",
    "config-management",
    "flag-evaluation",
    "resolution",
    "engine",
    "targeting",
    "schema",
    "specification",
    "showwhat"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yeojz/showwhat.git",
    "directory": "packages/showwhat"
  },
  "homepage": "https://showwhat.yeojz.dev",
  "bugs": {
    "url": "https://github.com/yeojz/showwhat/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .tsbuildinfo",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@showwhat/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}
