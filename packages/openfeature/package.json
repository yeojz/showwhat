{
  "name": "@showwhat/openfeature",
  "version": "2.0.0",
  "description": "OpenFeature provider for showwhat library",
  "keywords": [
    "feature-flags",
    "openfeature",
    "openfeature-provider",
    "feature-management",
    "showwhat"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yeojz/showwhat.git",
    "directory": "packages/openfeature"
  },
  "homepage": "https://showwhat.yeojz.dev",
  "bugs": {
    "url": "https://github.com/yeojz/showwhat/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .tsbuildinfo",
    "lint": "eslint src",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "showwhat": "workspace:*"
  },
  "peerDependencies": {
    "@openfeature/server-sdk": "^1.0.0"
  },
  "devDependencies": {
    "@openfeature/server-sdk": "^1.20.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
