{
  "name": "@showwhat/s3",
  "version": "2.0.0",
  "description": "S3-compatible storage adapter for showwhat definitions",
  "keywords": [
    "showwhat",
    "s3",
    "storage",
    "feature-flags",
    "cloudflare-r2"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yeojz/showwhat.git",
    "directory": "packages/s3"
  },
  "homepage": "https://showwhat.yeojz.dev",
  "bugs": {
    "url": "https://github.com/yeojz/showwhat/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .tsbuildinfo",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@showwhat/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
