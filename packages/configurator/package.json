{
  "name": "@showwhat/configurator",
  "version": "1.0.0",
  "description": "Reusable configurator component library for showwhat feature flags",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/showwhat/showwhat.git",
    "directory": "packages/configurator"
  },
  "homepage": "https://github.com/showwhat/showwhat",
  "bugs": {
    "url": "https://github.com/showwhat/showwhat/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
